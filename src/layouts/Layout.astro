---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="A curated directory of open-source AI security tools. Find, filter, and evaluate scanners, guardrails, red-team frameworks, and more." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="A curated directory of open-source AI security tools. Find, filter, and evaluate scanners, guardrails, red-team frameworks, and more." />
    <meta property="og:url" content="https://aisectools.dev" />
    <meta property="og:type" content="website" />
    <meta name="author" content="Jonathan Thompson" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-zinc-100 font-sans antialiased" style="background-color: #0a1628;">
    <slot />
  </body>
</html>
