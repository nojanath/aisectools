---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Page Not Found - AISecTools">
  <div class="flex flex-col items-center justify-center min-h-screen p-4">
    <h1 class="text-7xl font-bold text-slate-700 mb-4 font-mono tracking-tight">404</h1>
    <p class="text-xl text-zinc-400 mb-8">Page not found</p>
    <a href="/" class="text-cyan-400 hover:text-cyan-300 font-medium border-b border-cyan-400/40 hover:border-cyan-300">Back to AI Security Tools</a>
  </div>
</Layout>
